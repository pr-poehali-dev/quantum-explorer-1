{
  "tests": [
    {
      "name": "Register with missing fields returns 400",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": ""},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "nobody@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Access me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify email with bad token returns 400",
      "method": "POST",
      "path": "/?action=verify-email",
      "body": {"token": "invalid_token_xyz"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    }
  ]
}
