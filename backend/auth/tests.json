{
  "tests": [
    {
      "name": "Login with valid credentials returns token",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_security@example.com", "password": "testpass123"},
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_security@example.com", "password": "wrongpassword"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Access me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Forged token is rejected with 401",
      "method": "GET",
      "path": "/?action=me",
      "headers": {"X-Auth-Token": "1:forged_signature_that_should_not_work"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Register with missing fields returns 400",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": ""},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    }
  ]
}